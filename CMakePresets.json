        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "qt-mingw-ninja",
      "configurePreset": "qt-mingw-ninja"
    }
  ]
